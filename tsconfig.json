{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "include": ["src", "test"],
  "compilerOptions": {
    "lib": ["es2024", "dom"],
    "target": "es2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["mocha", "chai"],
    "declaration": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "jsx": "react-jsx"
  }
}
